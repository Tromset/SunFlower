{
  "name": "sunflower",
  "version": "0.1.0",
  "private": true,
  "description": "100% local screen companion — the sunflower that watches your screen and answers out loud",
  "main": "dist/main/index.cjs",
  "bin": {
    "sunflower": "bin/sunflower.js",
    "sunflower-models": "bin/sunflower-models.js",
    "sunflower-requirements": "bin/sunflower-requirements.js"
  },
  "scripts": {
    "start": "node scripts/build.mjs && node bin/sunflower.js",
    "dev": "node scripts/build.mjs --watch",
    "build": "node scripts/build.mjs",
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "smart-whisper": "0.8.1",
    "uiohook-napi": "^1.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^43.1.1",
    "esbuild": "^0.27.3",
    "typescript": "^6"
  }
}
